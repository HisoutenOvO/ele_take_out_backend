<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="eleTakeOut.server.mapper.ShopMapper">
    <select id="pageQuery" resultType="eleTakeOut.pojo.entity.Shop">
        select * from shop
        <where>
            <if test="keyword != null and keyword != ''">
                name like concat('%',#{keyword},'%')
            </if>
        </where>
        order by update_time desc
    </select>
    <select id="getShopList" resultType="eleTakeOut.pojo.entity.ShopVO">
        select * from shop
        <where>
            <if test="keywords != null and keywords != ''">
                name like concat('%',#{keyword},'%')
            </if>
        </where>
        order by update_time desc
    </select>
</mapper>