<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="eleTakeOut.server.mapper.CartMapper">
    <select id="getByDishIdAndUserIdAndShopId" resultType="eleTakeOut.pojo.entity.Cart">
        select * from cart
        <where>
            <if test="dishId != null">
                dish_id = #{dishId}
            </if>
            <if test="userId != null">
                and user_id = #{userId}
            </if>
            <if test="shopId != null">
                and shop_id = #{shopId}
            </if>
        </where>
    </select>
</mapper>