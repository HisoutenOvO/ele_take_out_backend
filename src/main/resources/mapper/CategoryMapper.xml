<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="eleTakeOut.server.mapper.CategoryMapper">
    <delete id="deleteByShopIds">
        delete from category where shop_id in
        <foreach collection="shopIds" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </delete>
    <select id="getCategoryList" resultType="eleTakeOut.pojo.vo.CategoryDetailVO">
        select * from category
        <where>
            <if test="keyword != null">
                and name like concat('%',#{keyword},'%')
            </if>
            and shop_id = #{shopId}
        </where>
        order by update_time desc
    </select>
</mapper>