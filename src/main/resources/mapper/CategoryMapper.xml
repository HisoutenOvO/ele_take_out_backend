<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="eleTakeOut.server.mapper.CategoryMapper">
    <select id="getCategoryList" resultType="eleTakeOut.pojo.vo.CategoryVO">
        select * from category
        <where>
            <if test="categoryPageQueryDTO.keyword != null">
                and name like concat('%',#{keyword},'%')
            </if>
            and shop_id = #{shopId}
        </where>
        order by update_time desc
    </select>
</mapper>