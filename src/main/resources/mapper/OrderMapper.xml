<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="eleTakeOut.server.mapper.OrderMapper">
    <insert id="insertOrderDetailList">
        insert into order_detail(name,image,dish_id,number,amount,order_id) values
        <foreach collection="orderDetailList" item="item" separator=",">
            (#{item.name},#{item.image},#{item.dishId},#{item.number},#{item.amount},#{item.orderId})
        </foreach>
    </insert>
    <select id="pageQuery" resultType="eleTakeOut.pojo.vo.OrderListVO">
        select o.id,o.number,u.username,u.phone,o.status,o.total_price,o.actual_payment,o.create_time
        from orders o left join user u on o.user_id = u.id
        <where>
            <if test="status != null">
                and o.status = #{status}
            </if>
            and shop_id = #{shopId}
        </where>
        order by create_time desc
    </select>
</mapper>