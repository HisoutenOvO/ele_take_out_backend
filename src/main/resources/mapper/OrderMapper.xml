<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="eleTakeOut.server.mapper.OrderMapper">
    <insert id="insertOrderDetailList">
        insert into order_detail(name,image,dish_id,number,amount,order_id) values
        <foreach collection="orderDetailList" item="item" separator=",">
            (#{item.name},#{item.image},#{item.dishId},#{item.number},#{item.amount},#{item.orderId})
        </foreach>
    </insert>
</mapper>